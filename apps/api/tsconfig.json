{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@shared-types/*": ["../../packages/shared-types/src/*"],
      "@mahalaxmi/core/*": ["../../packages/core/src/*"],
      "@api/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
