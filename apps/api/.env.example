PORT=4000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
REDIS_URL=redis://localhost:6379

# Queue settings (set to true to bypass Redis locally and run workers synchronously)
DISABLE_QUEUES=true

# Storage Settings (Cloudflare R2 or AWS S3)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=photo-product-bucket
AWS_S3_PUBLIC_BASE_URL=https://eu-north-1.console.aws.amazon.com/s3/buckets/photo-product-bucket?region=eu-north-1&tab=objects

R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=product-image-store
R2_PUBLIC_BASE_URL=https://your-r2-account-id.r2.cloudflarestorage.com
